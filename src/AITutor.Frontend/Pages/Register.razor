@page "/register"
@using AITutor.Application.DTOs
@inject HttpClient Http
@inject ILocalStorageService LocalStorage
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="vh-100 d-flex align-center">
    <MudCard Elevation="4" Class="auth-card glass-panel pa-8">
        <div class="text-center mb-8">
            <MudText Typo="Typo.h4" Class="brand-text">Đăng Ký</MudText>
            <MudText Typo="Typo.body2">Bắt đầu hành trình học tập cùng AI Tutor</MudText>
        </div>

        <EditForm Model="@_registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />
            
            <MudTextField @bind-Value="_registerModel.Username" Label="Tên hiển thị" 
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-4" 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
            
            <MudTextField @bind-Value="_registerModel.Email" Label="Email" 
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-4" 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            
            <MudTextField @bind-Value="_registerModel.Password" Label="Mật khẩu" 
                          InputType="InputType.Password" Variant="Variant.Outlined" 
                          FullWidth="true" Class="mb-6"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />

            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" 
                       Color="Color.Primary" FullWidth="true" Size="Size.Large" 
                       Class="login-btn" Disabled="@_isProcessing">
                @if (_isProcessing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Đang tạo tài khoản...</MudText>
                }
                else
                {
                    <MudText>Đăng Ký Ngay</MudText>
                }
            </MudButton>
        </EditForm>

        <div class="text-center mt-6">
            <MudLink href="/login">Đã có tài khoản? Đăng nhập thôi!</MudLink>
        </div>
    </MudCard>
</MudContainer>

<style>
    .vh-100 { min-height: 90vh; }
    
    .auth-card {
        border-radius: 24px;
        width: 100%;
        animation: cardEnter 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .login-btn {
        background: linear-gradient(135deg, #1746FF 0%, #0077FF 100%);
        border-radius: 12px;
        height: 52px;
        font-weight: 700;
        text-transform: none;
        font-size: 1.1rem;
        box-shadow: 0 10px 20px rgba(23, 70, 255, 0.2);
    }

    @keyframes cardEnter {
        from { opacity: 0; transform: scale(0.9) translateY(20px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
</style>

@code {
    private RegisterModel _registerModel = new();
    private bool _isProcessing = false;

    private async Task HandleRegister()
    {
        _isProcessing = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", _registerModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();
                if (result != null)
                {
                    await LocalStorage.SetItemAsync("authToken", result.Token);
                    await LocalStorage.SetItemAsync("userData", result);
                    Snackbar.Add($"Đăng ký thành công! Chào mừng {result.Username}!", Severity.Success);
                    Nav.NavigateTo("/");
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Lỗi: {error}", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Có lỗi xảy ra kết nối đến server.", Severity.Error);
        }
        finally { _isProcessing = false; }
    }

    public class RegisterModel
    {
        public string Username { get; set; } = "";
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
    }
}
