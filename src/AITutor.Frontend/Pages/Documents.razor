@page "/documents"
@using AITutor.Domain.Entities
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject ILocalStorageService LocalStorage

<MudText Typo="Typo.h4" Class="brand-text mb-6">Tài Liệu Của Bạn</MudText>

<MudGrid>
    <MudItem xs="12" md="4">
        <MudCard Elevation="4" Class="glass-panel pa-6">
            <MudText Typo="Typo.h6" Class="mb-4">Tải lên tài liệu</MudText>
            
            <MudTextField @bind-Value="_topic" Label="Chủ đề (ví dụ: Grammar, Travel)" Variant="Variant.Outlined" Class="mb-4" />
            
            <MudSelect @bind-Value="_difficulty" Label="Độ khó" Variant="Variant.Outlined" Class="mb-4">
                <MudSelectItem Value="@("Beginner")">Cơ bản</MudSelectItem>
                <MudSelectItem Value="@("Intermediate")">Trung cấp</MudSelectItem>
                <MudSelectItem Value="@("Advanced")">Nâng cao</MudSelectItem>
            </MudSelect>

            <MudFileUpload T="IBrowserFile" FilesChanged="UploadFile">
                <ButtonTemplate>
                    <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" 
                               StartIcon="@Icons.Material.Filled.CloudUpload" for="@context">
                        Chọn File PDF
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            @if (_isUploading)
            {
                <MudProgressLinear Color="Color.Info" Indeterminate="true" Class="mt-4" />
                <MudText Typo="Typo.caption" Class="mt-2">Đang xử lý RAG & Vectorize...</MudText>
            }
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="8">
        <MudTable Items="@_documents" Hover="true" Elevation="4" Class="glass-panel" 
                  Loading="@_loading" LoadingProgressColor="Color.Info">
            <HeaderContent>
                <MudTh>Tên File</MudTh>
                <MudTh>Chủ đề</MudTh>
                <MudTh>Độ khó</MudTh>
                <MudTh>Ngày tải</MudTh>
                <MudTh>Trạng thái</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="File">@context.FileName</MudTd>
                <MudTd DataLabel="Topic">@context.Topic</MudTd>
                <MudTd DataLabel="Diff">@context.Difficulty</MudTd>
                <MudTd DataLabel="Date">@context.UploadedAt.ToShortDateString()</MudTd>
                <MudTd DataLabel="Status">
                    @if (context.IsProcessed)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Sẵn sàng</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small">Đang xử lý</MudChip>
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudItem>
</MudGrid>

@code {
    private List<Document> _documents = new();
    private string _topic = "";
    private string _difficulty = "Beginner";
    private bool _loading = true;
    private bool _isUploading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        _loading = true;
        try
        {
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            _documents = await Http.GetFromJsonAsync<List<Document>>("api/documents") ?? new();
        }
        finally { _loading = false; }
    }

    private async Task UploadFile(IBrowserFile file)
    {
        if (string.IsNullOrWhiteSpace(_topic))
        {
            Snackbar.Add("Vui lòng nhập chủ đề trước khi tải lên.", Severity.Warning);
            return;
        }

        _isUploading = true;
        try
        {
            using var content = new MultipartFormDataContent();
            var fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024));
            content.Add(fileContent, "file", file.Name);
            content.Add(new StringContent(_topic), "topic");
            content.Add(new StringContent(_difficulty), "difficulty");

            var response = await Http.PostAsync("api/documents/upload", content);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Tải lên và xử lý thành công!", Severity.Success);
                _topic = "";
                await LoadDocuments();
            }
            else
            {
                Snackbar.Add("Lỗi khi tải file.", Severity.Error);
            }
        }
        finally { _isUploading = false; }
    }
}
