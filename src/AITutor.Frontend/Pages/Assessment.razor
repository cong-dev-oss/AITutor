@page "/assessment"
@using AITutor.Infrastructure.Services
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject NavigationManager nav

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudCard Elevation="4" Class="glass-panel pa-8">
        <div class="text-center mb-8">
            <MudText Typo="Typo.h4" Class="brand-text">Kiểm Tra Trình Độ</MudText>
            <MudText Typo="Typo.body1">Làm bài test 5 câu để xác định Level của bạn.</MudText>
        </div>

        @if (_questions == null)
        {
            <div class="d-flex flex-column align-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                <MudText Typo="Typo.body2" Class="mt-4">AI đang soạn bài thi từ tài liệu của bạn...</MudText>
            </div>
        }
        else if (!_isFinished)
        {
            <div class="question-container anim-fade">
                <MudText Typo="Typo.h6" Class="mb-4">Câu @_currentIdx+1: @_questions[_currentIdx].Question</MudText>
                
                <MudRadioGroup @bind-Value="_selectedOption" T="int">
                    @for (int i = 0; i < _questions[_currentIdx].Options.Length; i++)
                    {
                        var optIdx = i;
                        <MudRadio Value="@optIdx" Color="Color.Primary" Class="mb-2">@_questions[_currentIdx].Options[i]</MudRadio><br />
                    }
                </MudRadioGroup>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                           Class="mt-6" OnClick="NextQuestion" 
                           Disabled="@(_selectedOption == -1)">
                     Tiếp Theo (@(_currentIdx + 1)/5)
                </MudButton>
            </div>
        }
        else
        {
            <div class="text-center anim-fade">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" Class="mb-4" />
                <MudText Typo="Typo.h5">Chúc mừng! Bạn đã hoàn thành.</MudText>
                <MudText Typo="Typo.h6" Class="my-4">Trình độ đề xuất: <span class="brand-text">@_newLevel</span></MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => nav.NavigateTo("/"))">Bắt đầu học ngay</MudButton>
            </div>
        }
    </MudCard>
</MudContainer>

<style>
    .question-container {
        padding: 24px;
        background: rgba(0,0,0,0.02);
        border-radius: 12px;
    }
</style>

@code {
    private List<QuestionDto>? _questions;
    private int _currentIdx = 0;
    private int _selectedOption = -1;
    private int _score = 0;
    private bool _isFinished = false;
    private string _newLevel = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _questions = await Http.GetFromJsonAsync<List<QuestionDto>>("api/placement-test/generate");
        }
        catch (Exception)
        {
            Snackbar.Add("Lỗi khi tải bài thi từ server.", Severity.Error);
        }
    }

    private async Task NextQuestion()
    {
        if (_selectedOption == _questions?[_currentIdx].CorrectIndex) _score++;
        
        _selectedOption = -1;
        _currentIdx++;

        if (_currentIdx >= 5)
        {
            await SubmitResult();
        }
    }

    private async Task SubmitResult()
    {
        var response = await Http.PostAsJsonAsync("api/placement-test/submit", _score);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<dynamic>();
            _newLevel = result?.newLevel ?? "A1";
            _isFinished = true;
        }
    }
}
